# Shared configuration for both local and Docker runs.
# Copy this file to .env. Docker overrides only the values that are different.

# Backend / API
OCKHAM_API_HOST=127.0.0.1
OCKHAM_API_PORT=8000
OCKHAM_LOG_LEVEL=INFO
OCKHAM_LOG_TO_FILE=true
OCKHAM_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# LLM
# These values are written for local development. Docker overrides only what is
# different at container runtime through docker-compose.yml.
OCKHAM_ENABLE_LLM_RANKING=true
OCKHAM_OLLAMA_BASE_URL=http://127.0.0.1:11434
OCKHAM_OLLAMA_MODEL=llama3.2:3b
OCKHAM_OLLAMA_TIMEOUT_SECONDS=120
OCKHAM_OLLAMA_TEMPERATURE=0.0
OCKHAM_OLLAMA_MAX_RETRIES=1
OCKHAM_OLLAMA_KEEP_ALIVE=10m

# Frontend
# The same value works in Vite dev and in Docker because both environments
# proxy /api requests to the backend.
VITE_API_BASE_URL=/api

# Local Vite proxy target
OCKHAM_FRONTEND_PROXY_TARGET=http://127.0.0.1:8000

# Optional: uncomment if your Docker host needs an HTTPS proxy for model downloads
# HTTPS_PROXY=https://proxy.example.com:8443
